 		char *rcrc;
 		int fd;
+		char *rcrc_env;
+		bool push_interactive;
 
-		rcrc = concat(varlookup("home"), word("/.rcrc", NULL))->w;
-		fd = rc_open(rcrc, rFrom);
-		if (fd == -1) {
-			if (errno != ENOENT)
-				uerror(rcrc);
+		rcrc_env = getenv("RCRC");
+		if (rcrc_env != NULL) {
+			fd = rc_open(rcrc_env, rFrom);
+			if (fd >= 0) {
+				pushfd(fd);
+				push_interactive = interactive;
+				interactive = FALSE;
+				doit(TRUE);
+				interactive = push_interactive;
+				close(fd);
+			} else if (errno != ENOENT) {
